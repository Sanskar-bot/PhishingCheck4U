# =====================================================
# PhishingCheck4U — Environment Variables Template
# =====================================================
# 1. Copy this file:  copy .env.example .env
# 2. Fill in your values below
# 3. NEVER commit .env to version control
# =====================================================

# Your Gmail address
EMAIL_ADDRESS=phishingcheck4u@gmail.com

# Gmail App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Requires 2FA to be enabled on your Google account
EMAIL_APP_PASSWORD=44561237897894

# Mail servers (Gmail defaults - do not change)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Database (SQLite default - works out of the box)
DATABASE_URL=sqlite:///./phishingcheck4u.db

# Optional OSINT API Keys (leave blank to skip those checks)
# AbuseIPDB:   https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# VirusTotal:  https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# App settings
LOG_LEVEL=INFO
MAX_EMAILS_PER_RUN=20
POLL_INTERVAL_SECONDS=60

# Set to False to disable auto-reply emails (useful for testing)
REPORT_REPLY_ENABLED=True
